{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/admin(.*)", "destination": "/admin$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/projects/(.*)", "destination": "/projects/$1" },
    { "source": "/style.css", "destination": "/style.css" },
    { "source": "/main.js", "destination": "/main.js" },
    { "source": "/explorations", "destination": "/explorations" },
    { "source": "/:category/:project", "destination": "/project" },
    { "source": "/:category", "destination": "/index" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/projects/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
